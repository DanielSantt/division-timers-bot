# Token do bot (Discord Developer Portal -> Bot -> Reset Token)
DISCORD_TOKEN=coloque_seu_token_aqui

# Application ID (Discord Developer Portal -> General Information -> Application ID)
CLIENT_ID=coloque_o_application_id_aqui

# ID do servidor onde os slash commands vão ser registrados
# (ative o Modo Desenvolvedor no Discord, clique com botão direito no servidor -> Copiar ID)
GUILD_ID=coloque_o_id_do_servidor_aqui

# ID do canal onde a mensagem de timers vai ficar fixa
CHANNEL_ID=coloque_o_id_do_canal_aqui

# Chave da API da Anthropic (console.anthropic.com), usada pelo comando /atualizar-timers
# para pesquisar os horários atuais na web. Sem essa chave, o comando de pesquisa não funciona,
# mas /definir-manutencao e /definir-sotg continuam funcionando normalmente.
ANTHROPIC_API_KEY=coloque_sua_chave_aqui
